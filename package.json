{
  "name": "arbeidsflytsportal",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:core": "turbo run dev --parallel --filter=@apps/api --filter=@apps/web",
    "dev:api": "pnpm --filter @apps/api dev",
    "dev:web": "pnpm --filter @apps/web dev",
    "infra:up": "docker compose up -d postgres",
    "tunnel:up": "docker compose --profile https --profile tunnel up -d https tunnel",
    "tunnel:down": "docker compose --profile https --profile tunnel stop tunnel https",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.2",
    "prettier": "^3.5.2",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}

