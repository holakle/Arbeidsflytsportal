# Postgres credentials used by docker-compose postgres service.
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=CHANGE_ME_DB_NAME

# API connection string used by apps/api and Prisma CLI.
DATABASE_URL=postgresql://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@localhost:5432/CHANGE_ME_DB_NAME?schema=public

# Local app ports.
API_PORT=3001
WEB_PORT=3000

# JWT settings for local dev auth.
JWT_ISSUER=workflow-dev
JWT_AUDIENCE=workflow-clients
JWT_SECRET=CHANGE_ME_JWT_SECRET

# Comma-separated origins allowed by API CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# API rate limiting defaults.
# Time-to-live window in milliseconds (60000 ms = 60 seconds).
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120

# Enable local dev auth endpoints.
ENABLE_DEV_AUTH=true

# Enable overview/debug UI.
NEXT_PUBLIC_ENABLE_OVERVIEW=true

# Local LAN host used by Caddy profile.
LAN_HOST=workflow.local

# Optional Cloudflare named tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=
