POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow
POSTGRES_DB=workflow_portal
DATABASE_URL=postgresql://workflow:workflow@localhost:5432/workflow_portal?schema=public
API_PORT=3001
WEB_PORT=3000
JWT_ISSUER=workflow-dev
JWT_AUDIENCE=workflow-clients
JWT_SECRET=replace-with-a-strong-random-secret
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
ENABLE_DEV_AUTH=true
# DEV_TOKEN is a server-only variable (not NEXT_PUBLIC_) - set in .env.local for development
# DEV_TOKEN=
NEXT_PUBLIC_ENABLE_OVERVIEW=true
LAN_HOST=workflow.local
CLOUDFLARE_TUNNEL_TOKEN=

