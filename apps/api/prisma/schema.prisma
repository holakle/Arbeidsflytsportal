generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  departments Department[]
  locations   Location[]
  projects    Project[]
  users       User[]
  teams       Team[]
  roles       Role[]
  userRoles   UserRole[]
  workOrders  WorkOrder[]
  equipmentItems EquipmentItem[]
  timesheetEntries TimesheetEntry[]
  todoItems   TodoItem[]
  dashboards  Dashboard[]
  auditLogs   AuditLog[]
  workOrderConsumables WorkOrderConsumable[]
  workOrderSchedules WorkOrderSchedule[]
  workSessions WorkSession[]
  attachments Attachment[]
  notifications Notification[]
}

model Department {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
  workOrders     WorkOrder[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Location {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
  workOrders     WorkOrder[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Project {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  workOrders     WorkOrder[]
  timesheetEntries TimesheetEntry[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  displayName    String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  teamMemberships TeamMembership[]
  assignments    Assignment[] @relation("AssignmentUser")
  workOrdersCreated WorkOrder[] @relation("WorkOrderCreator")
  plannedWorkOrders WorkOrder[] @relation("WorkOrderPlanningOwner")
  scheduleEntries WorkOrderSchedule[] @relation("ScheduleUser")
  timesheetEntries TimesheetEntry[]
  todoItems      TodoItem[]
  dashboards     Dashboard[]
  auditLogs      AuditLog[] @relation("AuditActor")
  workSessions   WorkSession[]
  attachments    Attachment[]
  notifications  Notification[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Role {
  id             String   @id @default(uuid())
  code           String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  @@unique([organizationId, code])
}

model UserRole {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId         String
  role           Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId, roleId, organizationId])
}

model Team {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    TeamMembership[]
  assignments    Assignment[] @relation("AssignmentTeam")
  scheduleEntries WorkOrderSchedule[] @relation("ScheduleTeam")
  todoItems      TodoItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TeamMembership {
  id        String @id @default(uuid())
  teamId    String
  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([teamId, userId])
}

model Dashboard {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets        WidgetInstance[]
  layout         DashboardLayout?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([organizationId, userId])
}

model WidgetInstance {
  id          String @id @default(uuid())
  dashboardId String
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type        String
  title       String
  config      Json
}

model DashboardLayout {
  id          String @id @default(uuid())
  dashboardId String @unique
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  columns     Int @default(4)
  layout      Json
}

model AuditLog {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId    String?
  actorUser      User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String
  entityType     String
  entityId       String
  before         Json?
  after          Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime @default(now())
}

model WorkOrder {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         WorkOrderStatus @default(READY_FOR_PLANNING)
  customerName   String?
  contactName    String?
  contactPhone   String?
  addressLine1   String?
  postalCode     String?
  city           String?
  lat            Decimal? @db.Decimal(10,7)
  lng            Decimal? @db.Decimal(10,7)
  accessNotes    String?
  hmsNotes       String?
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdByUserId String
  createdByUser   User @relation("WorkOrderCreator", fields: [createdByUserId], references: [id])
  planningOwnerUserId String?
  planningOwnerUser   User? @relation("WorkOrderPlanningOwner", fields: [planningOwnerUserId], references: [id], onDelete: SetNull)
  assignments    Assignment[]
  schedules      WorkOrderSchedule[]
  tasks          WorkTask[]
  reservations   EquipmentReservation[]
  consumables    WorkOrderConsumable[]
  timesheetEntries TimesheetEntry[]
  workSessions   WorkSession[]
  attachments    Attachment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model WorkTask {
  id          String @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  title       String
  done        Boolean @default(false)
}

model Assignment {
  id             String @id @default(uuid())
  workOrderId    String
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assigneeUserId String?
  assigneeUser   User? @relation("AssignmentUser", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeTeamId String?
  assigneeTeam   Team? @relation("AssignmentTeam", fields: [assigneeTeamId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
}

model EquipmentItem {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  serialNumber   String?
  barcode        String?
  type           EquipmentItemType @default(EQUIPMENT)
  active         Boolean @default(true)
  reservations   EquipmentReservation[]
  consumptions   WorkOrderConsumable[]
  @@unique([organizationId, barcode])
}

enum EquipmentItemType {
  EQUIPMENT
  CONSUMABLE
}

model WorkOrderConsumable {
  id              String @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workOrderId     String
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id], onDelete: Cascade)
  quantity        Int @default(1)
  note            String?
  createdAt       DateTime @default(now())

  @@index([workOrderId, createdAt])
  @@index([equipmentItemId])
}

model WorkOrderSchedule {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workOrderId    String
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assigneeUserId String?
  assigneeUser   User? @relation("ScheduleUser", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeTeamId String?
  assigneeTeam   Team? @relation("ScheduleTeam", fields: [assigneeTeamId], references: [id], onDelete: SetNull)
  startAt        DateTime
  endAt          DateTime
  note           String?
  status         String @default("PLANNED")
  createdAt      DateTime @default(now())

  @@index([organizationId, assigneeUserId, startAt])
  @@index([organizationId, assigneeTeamId, startAt])
  @@index([organizationId, workOrderId, startAt])
}

model EquipmentReservation {
  id              String @id @default(uuid())
  equipmentItemId String
  equipmentItem   EquipmentItem @relation(fields: [equipmentItemId], references: [id], onDelete: Cascade)
  workOrderId     String
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  startAt         DateTime
  endAt           DateTime
  @@index([equipmentItemId, startAt, endAt])
}

model TimesheetEntry {
  id             String @id @default(uuid())
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime
  hours          Decimal @db.Decimal(5,2)
  activityType   String
  workOrderId    String?
  workOrder      WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  note           String?
  status         TimesheetStatus @default(DRAFT)
  submittedAt    DateTime @default(now())
}

model TodoItem {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  status         String @default("OPEN")
  dueDate        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WorkSession {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workOrderId    String
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt      DateTime
  endedAt        DateTime?
  state          WorkSessionState @default(RUNNING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId, state])
  @@index([organizationId, workOrderId, startedAt])
}

model Attachment {
  id               String @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workOrderId      String
  workOrder        WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  uploadedByUser   User @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  kind             AttachmentKind @default(GENERAL)
  mimeType         String
  size             Int
  storageKey       String
  url              String?
  createdAt        DateTime @default(now())

  @@index([organizationId, workOrderId, createdAt])
}

model Notification {
  id             String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  payload        Json
  readAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId, createdAt])
  @@index([organizationId, userId, readAt])
}

enum WorkOrderStatus {
  DRAFT
  READY_FOR_PLANNING
  PLANNED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum WorkSessionState {
  RUNNING
  PAUSED
  DONE
}

enum AttachmentKind {
  BEFORE
  AFTER
  GENERAL
  DEVIATION
  SIGNATURE
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum NotificationType {
  WORKORDER_ASSIGNED
  SCHEDULE_CHANGED
  WORKORDER_BLOCKED
  WORKORDER_DONE
}

