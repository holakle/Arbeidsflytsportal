{$LAN_HOST:localhost} {
  tls internal
  encode gzip

  handle_path /api/* {
    reverse_proxy host.docker.internal:3001
  }

  handle {
    reverse_proxy host.docker.internal:3000
  }
}

:80 {
  encode gzip

  handle_path /api/* {
    reverse_proxy host.docker.internal:3001
  }

  handle {
    reverse_proxy host.docker.internal:3000
  }
}
